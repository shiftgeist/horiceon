#!/usr/local/bin/deno run --allow-env --allow-read --allow-sys --allow-net --allow-run

import { load } from "jsr:@std/dotenv@0.225.7";
import { z } from 'jsr:@zod/zod@4.4.3/v4';
import { homedir } from "node:os";

const envSchema = z.object({
  SEMS_ACCOUNT: z.string(),
  SEMS_PASSWORD: z.string(),
  SEMS_STATION_ID: z.string(),
})

const env = await load({ envPath: `${homedir()}/.horiceon/.env` }).then(rawEnv => {
  const parsed = envSchema.safeParse(rawEnv)
  if (parsed.error) throw parsed.error;
  return parsed.data;
})

const outputBar = process.env.SWIFTBAR === "1";
const ignoreLowPower = process.env.LOWPOWER === "0";

try {
  const { stdout } = await Deno.spawnAndWait("pmset", {
    args: ["-g"],
  });
  const output = new TextDecoder().decode(stdout).trim();

  const isLowPowerMode = output.replaceAll(" ", "").includes("lowpowermode1");

  if (isLowPowerMode && !ignoreLowPower) {
    console.log(`💤`);
    process.exit(0);
  }
} catch {
  console.log(`Error in lowpowermode check`);
  process.exit(0);
}

const NOISE_FILTER_W = 10

interface SemsEnvelope<T> {
  hasError: boolean;
  code: number;
  msg: string;
  data: T;
  api?: string;
}

interface LoginToken {
  uid: string;
  timestamp: number;
  token: string;
  client: string;
  version: string;
  language: string;
}

interface PowerFlowGet {
  powerflow: PowerFlow;
}

function parseWStrToKW(value: string): number {
  return Math.round(parseFloat(value) / 10) / 100;
}

function noiseFilter(val: number): number | string {
  return val < NOISE_FILTER_W ? '??' : val;
}

function parseKwText(val: number) {
  return `${val > 0 ? "+" : ""}${val}kW`
}

const PowerFlowSchema = z.object({
  pv: z.string().transform(parseWStrToKW),
  bettery: z.string().transform(parseWStrToKW),
  betteryStatus: z.number(), // -1=discharging, 1=charging, 3=charging ?
  load: z.string().transform(parseWStrToKW).transform(noiseFilter),
  loadStatus: z.number(),
  grid: z.string().transform(parseWStrToKW),
  soc: z.number(),
})
type PowerFlow = z.infer<typeof PowerFlowSchema>

function scaleToBar(value: number, min: number, max: number, chars: string[]) {
  const ratio = (value - min) / (max - min);
  const index = Math.max(
    0,
    Math.min(chars.length - 1, Math.floor(ratio * chars.length)),
  );
  return chars[index];
}

async function login(): Promise<{ apiBaseUrl: string; token: LoginToken }> {
  const response = await fetch(
    "https://www.semsportal.com/api/v2/Common/CrossLogin",
    {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        Token: JSON.stringify({
          version: "v2.1.0",
          client: "ios",
          language: "en",
        }),
      },
      body: JSON.stringify({ account: env.SEMS_ACCOUNT, pwd: env.SEMS_PASSWORD }),
    },
  );

  const body: SemsEnvelope<LoginToken> = await response.json();
  if (body.hasError || !body.api) {
    throw new Error(`Login failed: ${body.msg}`);
  }

  return { apiBaseUrl: body.api, token: body.data };
}

async function getPowerflow(
  apiBaseUrl: string,
  token: LoginToken,
): Promise<PowerFlow> {
  const response = await fetch(
    `${apiBaseUrl}v2/PowerStation/GetPowerflow`,
    {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        Token: JSON.stringify(token),
      },
      body: JSON.stringify({ PowerStationId: env.SEMS_STATION_ID }),
    },
  );

  const body: SemsEnvelope<PowerFlowGet> = await response.json();
  if (body.hasError) {
    throw new Error(`Fetching inverter data failed: ${body.msg}`);
  }


  const parse = PowerFlowSchema.safeParse(body.data.powerflow)
  if (parse.error) throw parse.error;

  return parse.data;
}

async function main() {
  const { apiBaseUrl, token } = await login();
  const pf = await getPowerflow(apiBaseUrl, token);

  const charge = pf.bettery * pf.betteryStatus

  const iconsBattery = scaleToBar(pf.soc, 10, 95, ["🟥", "🟧", "🟨", "⬜", "🟦", "🟩", "⛽❇️"]);
  const iconsWatts = scaleToBar(pf.betteryStatus, -1, 1, ["▼", "", "▲"]);

  console.log(`${iconsBattery}${iconsWatts}`);
  console.log("---");
  console.log(`☀️ ${pf.pv}kW`);
  console.log(`${pf.soc}% (${parseKwText(charge)} = ${pf.bettery} * ${pf.betteryStatus})`);
  console.log(`Load ${pf.load} ${pf.loadStatus}`);

  console.log(`Last Updated: ${Temporal.Now.plainTimeISO().toString({ smallestUnit: 'minute' })} | refresh=true`);
  console.log(`Station ↗️ | href=https://www.semsportal.com/powerstation/PowerStatusSnMin/${env.SEMS_STATION_ID}`);

  if (!outputBar) {
    console.log(JSON.stringify(pf, null, 2));
  }
}

main().catch((error) => {
  const msg = error instanceof Error ? error.message : String(error);
  console.error(msg);
  process.exit(1);
});
