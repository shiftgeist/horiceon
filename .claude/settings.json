{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(buildin cd *)",
      "Bash(cat **)",
      "Bash(cd * && cat *)",
      "Bash(cd * && grep *)",
      "Bash(dprint fmt *)",
      "Bash(fd *)",
      "Bash(find *)",
      "Bash(fzf *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git status *)",
      "Bash(pnpm * test *)",
      "Bash(grep **)",
      "Bash(head **)",
      "Bash(ls **)",
      "Bash(mkdir **)",
      "Bash(rg *)",
      "Bash(rga *)",
      "Bash(trivy-scan *)",
      "Bash(wc -c *)",
      "Bash(yq *)",
      "Edit(~/.claude/CLAUDE.md)",
      "Read(~/.claude/CLAUDE.md)"
    ],
    "deny": [
      "Bash(git reset*)"
    ],
    "ask": [
      "Bash(rm *)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0
  },
  "autoUpdatesChannel": "stable"
}
