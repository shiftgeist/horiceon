#!/usr/bin/env -S bun --env-file=/Users/felix/.horiceon/.env

declare const process: any;

// const outputJson = process.argv.includes("--json");

enum BatteryStatus {
  Charging = "charging",
  Discharging = "discharging",
  Idle = "idle",
}

const POSITIVE_POWER_MEANS: BatteryStatus.Charging | BatteryStatus.Discharging = BatteryStatus.Discharging;
const IDLE_THRESHOLD_WATTS = 10;

interface SemsEnvelope<T> {
  hasError: boolean;
  code: number;
  msg: string;
  data: T;
  api?: string;
}

interface LoginToken {
  uid: string;
  timestamp: number;
  token: string;
  client: string;
  version: string;
  language: string;
}

interface InverterSummary {
  invert_full: {
    soc: string | number;
    vbattery1: string | number;
    ibattery1: string | number;
  };
}

interface MonitorDetail {
  inverter: InverterSummary[];
}

const SEMS_ACCOUNT = requireEnv("SEMS_ACCOUNT");
const SEMS_PASSWORD = requireEnv("SEMS_PASSWORD");
const SEMS_STATION_ID = requireEnv("SEMS_STATION_ID");

function requireEnv(name: string): string {
  const value = process.env[name];
  if (!value) {
    const msg = `Missing required env var: ${name}`;
    console.error(msg);
    process.exit(1);
  }
  return value;
}

function parseNumber(value: string | number): number {
  return typeof value === "number" ? value : parseFloat(value);
}

function flip(status: BatteryStatus.Charging | BatteryStatus.Discharging): BatteryStatus.Charging | BatteryStatus.Discharging {
  return status === BatteryStatus.Charging ? BatteryStatus.Discharging : BatteryStatus.Charging;
}

function getBatteryStatus(batteryPowerWatts: number): BatteryStatus {
  if (Math.abs(batteryPowerWatts) < IDLE_THRESHOLD_WATTS) {
    return BatteryStatus.Idle;
  }

  const isPositivePower = batteryPowerWatts > 0;
  return isPositivePower ? POSITIVE_POWER_MEANS : flip(POSITIVE_POWER_MEANS);
}

async function login(): Promise<{ apiBaseUrl: string; token: LoginToken }> {
  const response = await fetch("https://www.semsportal.com/api/v2/Common/CrossLogin", {
    method: "POST",
    headers: {
      "Content-Type": "application/json",
      Token: JSON.stringify({ version: "v2.1.0", client: "ios", language: "en" }),
    },
    body: JSON.stringify({ account: SEMS_ACCOUNT, pwd: SEMS_PASSWORD }),
  });

  const body: SemsEnvelope<LoginToken> = await response.json();
  if (body.hasError || !body.api) {
    throw new Error(`Login failed: ${body.msg}`);
  }

  return { apiBaseUrl: body.api, token: body.data };
}

async function fetchMonitorDetail(apiBaseUrl: string, token: LoginToken): Promise<MonitorDetail> {
  const response = await fetch(`${apiBaseUrl}v2/PowerStation/GetMonitorDetailByPowerstationId`, {
    method: "POST",
    headers: {
      "Content-Type": "application/json",
      Token: JSON.stringify(token),
    },
    body: JSON.stringify({ powerStationId: SEMS_STATION_ID }),
  });

  const body: SemsEnvelope<MonitorDetail> = await response.json();
  if (body.hasError) {
    throw new Error(`Fetching inverter data failed: ${body.msg}`);
  }

  return body.data;
}

async function main() {
  const { apiBaseUrl, token } = await login();
  const monitorDetail = await fetchMonitorDetail(apiBaseUrl, token);

  const inverter = monitorDetail.inverter[0];
  if (!inverter) {
    throw new Error("No inverter data returned for this station.");
  }

  const soc = parseNumber(inverter.invert_full.soc);
  const batteryVoltage = parseNumber(inverter.invert_full.vbattery1);
  const batteryCurrent = parseNumber(inverter.invert_full.ibattery1);
  const batteryPowerWatts = batteryVoltage * batteryCurrent;
  const status = getBatteryStatus(batteryPowerWatts);

  console.log(`🔋${status === BatteryStatus.Idle ? '😴' : (status === BatteryStatus.Charging ? '📈' : '📉')} ${soc}%`);
}

main().catch((error) => {
  const msg = error instanceof Error ? error.message : String(error);
  console.error(msg);
  process.exit(1);
});